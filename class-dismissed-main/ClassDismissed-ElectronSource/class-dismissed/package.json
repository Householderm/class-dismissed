{
  "name": "class-dismissed",
  "version": "1.0.0",
  "description": "Free retirement planner for public school teachers",
  "main": "main.js",
  "repository": "https://github.com/Householderm/class-dismissed",
  "author": "Class Dismissed — Teacher Retirement Planner",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64",
    "build:mac": "electron-builder --mac --x64 --arm64",
    "build:all": "electron-builder --win --mac --x64"
  },
  "build": {
    "appId": "com.classdismissed.retirementplanner",
    "productName": "Class Dismissed",
    "copyright": "© 2025 Class Dismissed",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "app.html",
      "assets/**"
    ],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Class Dismissed"
    },
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["x64"] },
        { "target": "dmg", "arch": ["arm64"] }
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.finance"
    },
    "dmg": {
      "title": "Class Dismissed Installer",
      "background": null,
      "window": { "width": 540, "height": 380 }
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}
